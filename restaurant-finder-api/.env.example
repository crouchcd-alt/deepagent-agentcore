# =============================================================================
# Restaurant Finder API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Values marked with (CDK) come from CDK stack outputs after deployment:
#   aws cloudformation describe-stacks --stack-name restaurantFinder-AgentCoreStack \
#     --query 'Stacks[0].Outputs' --output table
# =============================================================================

# --- AWS Configuration ---
AWS_REGION=us-east-2

# --- AgentCore Configuration (from CDK stack outputs) ---
# Gateway URL for MCP tool routing (CDK output: GatewayUrl)
GATEWAY_URL=
# Gateway identifier (CDK output: GatewayId)
GATEWAY_ID=
# Runtime identifier - only needed for evaluation (CDK output: RuntimeId)
RUNTIME_ID=
# Memory identifier for conversation persistence (CDK output: MemoryId)
MEMORY_ID=

# --- Feature Flags ---
# Enable browser-based tools (restaurant_explorer, restaurant_research)
ENABLE_BROWSER_TOOLS=true
# Enable Bedrock Guardrails for content moderation
GUARDRAIL_ENABLED=true

# --- Observability ---
# Enable OpenTelemetry-based observability for CloudWatch GenAI Observability
AGENT_OBSERVABILITY_ENABLED=true
# Service name for tracing attribution
OTEL_SERVICE_NAME=restaurant-finder-agent

# --- Evaluation (for make eval-* targets) ---
# Agent ID for evaluation runs (CDK output: RuntimeId)
AGENT_ID=
# Agent ARN for evaluation invocations (CDK output: RuntimeArn)
AGENT_ARN=
