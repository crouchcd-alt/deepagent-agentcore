# =============================================================================
# VCF Extraction via Deepagent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running the pipeline.
# =============================================================================

# --- Langfuse Observability ---
# Public key for Langfuse project (get from https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
# Secret key for Langfuse project
LANGFUSE_SECRET_KEY=
# Langfuse host (use https://cloud.langfuse.com for cloud, or self-hosted URL)
LANGFUSE_HOST=https://cloud.langfuse.com

# --- AWS Configuration ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Agent Execution Governance ---
# Maximum wall-clock time (seconds) before the agent run is terminated
AGENT_TIMEOUT_SECONDS=120
# Maximum number of agent iterations before termination
AGENT_MAX_ITERATIONS=10

# --- Output ---
# Local path to save the final JSON extraction results
OUTPUT_JSON_PATH=vcf_extraction_results.json
