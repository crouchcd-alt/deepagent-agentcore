# =============================================================================
# Clinical Extraction Pipeline - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running.
# =============================================================================

# --- Langfuse Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- AWS Configuration ---
AWS_REGION=us-east-1
AWS_PROFILE=

# --- Bedrock Models ---
# DeepAgent model for VCF extraction (code interpreter)
BEDROCK_AGENT_MODEL_ID=amazon.nova-lite-v1:0
# Extraction model for PDF structured output (low temp, JSON)
BEDROCK_EXTRACTION_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
# Vision model for multimodal PDF page fallback (supports images)
BEDROCK_VISION_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Agent Execution Limits ---
# Max tool calls per deepagent run before ToolCallLimitMiddleware raises
AGENT_MAX_TOOL_CALLS=30

# --- Output ---
OUTPUT_JSON_PATH=clinical_extraction_results.json
